# Base64-encoded contents of your Firebase service account JSON key file.
# Generate with (from the folder containing the key file):
#   Windows PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json")) | Set-Clipboard
#   macOS/Linux:         base64 -i serviceAccountKey.json | pbcopy
FIREBASE_SERVICE_ACCOUNT_JSON=

# API key from https://resend.com (free tier: 100 emails/day, 3000/month)
RESEND_API_KEY=

# Verified sender. Use Resend's shared testing domain if you haven't verified
# your own domain yet: "InstanceTrack <onboarding@resend.dev>"
RESEND_FROM=InstanceTrack <onboarding@resend.dev>

# IANA timezone your team's schedule is defined in
APP_TIMEZONE=Asia/Kolkata

# How many minutes before a slot starts to send the reminder
REMINDER_MINUTES_BEFORE=5
